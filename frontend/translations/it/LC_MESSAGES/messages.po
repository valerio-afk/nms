"Once you have opened PuTTY, select %(st_code)sSSH%(e_code)s in "
"%(st_em)sConnection type%(e_em)s."
msgstr ""
"Una volta scaricato, seleziona  %(st_code)sSSH%(e_code)s in "
"%(st_em)sConnection type%(e_em)s."

#: frontend/templates/card.access.ssh.html:64
#, python-format
msgid ""
"Insert the IP of this NAS (you can find in the Network tab) in "
"%(st_code)sHostname%(e_code)s."
msgstr ""
"Inserisci l'indirizzo IP di questo NAS (lo trovi nella pagina Rete) in "
"%(st_code)sHostname%(e_code)s."

#: frontend/templates/card.access.ssh.html:65
#, python-format
msgid "Change %(st_code)sPort%(e_code)s with %(st_code)s%(port)i%(e_code)s."
msgstr "Cambia %(st_code)sPort%(e_code)s con %(st_code)s%(port)i%(e_code)s."

#: frontend/templates/card.access.ssh.html:66
#, python-format
msgid "Press %(st_code)sOpen%(e_code)s."
msgstr "Premi %(st_code)sOpen%(e_code)s."

#: frontend/templates/card.access.ssh.html:67
#, python-format
msgid ""
"You will be asked for your %(st_code)slogin%(e_code)s (username) and "
"%(st_code)spassword%(e_code)s."
msgstr ""
"Ti verrà richiesta la tua %(st_code)slogin%(e_code)s (nome utente) e "
"%(st_code)spassword%(e_code)s."

#: frontend/templates/card.access.web.html:28
#, python-format
