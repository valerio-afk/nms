#, python-format
msgid "Open %(st_code)sPowershell%(e_code)s."
msgstr "Apri %(st_code)sPowershell%(e_code)s."

#: frontend/templates/card.access.nfs.html:127
#, python-format
msgid "You can choose a different unit letter than %(st_code)sZ:%(e_code)s."
msgstr ""
"Puoi scegliere un'unità con una lettera diversa da "
"%(st_code)sZ:%(e_code)s."

#: frontend/templates/card.access.smb.html:36
#, python-format
msgid "Open %(st_code)sFiles%(e_code)s."
msgstr "Apri %(st_code)sFile%(e_code)s."

#: frontend/templates/card.access.smb.html:37
#, python-format
msgid "Go to %(st_code)sOther locations%(e_code)s."
msgstr "Vai su %(st_code)sAltre posizioni%(e_code)s."

#: frontend/templates/card.access.smb.html:38
#, python-format
msgid ""
"Go to the textbox at the bottom saying %(st_code)sEnter server "
"address...%(e_code)s."
msgstr ""
"Vai nel campo di testo in basso con la dicitura %(st_code)sInserire "
"indirizzo server...%(e_code)s."

#: frontend/templates/card.access.smb.html:40
#, python-format
msgid ""
"Type %(st_code)ssmb://IP/NMS%(e_code)s. Replace %(st_code)sIP%(e_code)s "
"with the IP address/hostname of this NAS (you can find in the Network "
"tab)."
msgstr ""
"Scrivi %(st_code)ssmb://IP/NMS%(e_code)s. Sostituisci "
"%(st_code)sIP%(e_code)s con l'indirizzo IP/hostname di questo NAS (lo "
"puoi trovare nella pagina Rete)."

