msgstr "Premi %(st_code)sConnetti%(e_code)s"

#: frontend/templates/card.access.smb.html:42
#, python-format
msgid "When prompted, selected %(st_code)sRegistered user%(e_code)s."
msgstr "Quando richiesto, selezione %(st_code)sUtente registrato%(e_code)s."

#: frontend/templates/card.access.smb.html:43
#: frontend/templates/card.access.smb.html:112
#, python-format
msgid ""
"Type %(st_code)s%(uname)s%(e_code)s and the password you have set for "
"this service."
msgstr ""
"Scrivi %(st_code)s%(uname)s%(e_code)s e la password che hai impostato per"
" questo servizio."

#: frontend/templates/card.access.smb.html:62
#, python-format
msgid ""
"Install the Common Internet File System (%(st_code)sCIFS%(e_code)s) "
"utilities if they are not already in there. Here there are some "
"directions to it on major distributions:"
msgstr ""
"Installa il Common Internet File System (%(st_code)sCIFS%(e_code)s) se "
"non è già installato. Qui ci sono alcuni esempi per le distribuzioni più "
"importanti"

#: frontend/templates/card.access.smb.html:77
#: frontend/templates/card.access.ssh.html:47
