"Adapt %(st_code)s/media/nms%(e_code)s as per step (%(step)i) if you used "
"a different setup."
msgstr ""
"Cambia %(st_code)s/media/nms%(e_code)s in base a quello che hai fatto nel"
" passo (%(step)i)."

#: frontend/templates/card.access.nfs.html:96
#, python-format
msgid "Create a mount directory in %(st_code)s/Volumes%(e_code)s. For example"
