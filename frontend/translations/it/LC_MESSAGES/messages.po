#: frontend/templates/card.access.smb.html:109
#, python-format
msgid "Open %(st_code)sFile Manager%(e_code)s."
msgstr "Apri %(st_code)sEsplora file%(e_code)s."

#: frontend/templates/card.access.smb.html:110
#, python-format
msgid ""
"In the textbox for the path, insert %(st_code)s\\\\IP\\NMS%(e_code)s. "
"Replace %(st_code)sIP%(e_code)s with the IP address/hostname of this NAS "
"(you can find in the Network tab). Then, press %(st_code)sEnter%(e_code)s"
" key."
msgstr ""
"Nel campo di testo per il percorso, scrivi "
"%(st_code)s\\\\IP\\NMS%(e_code)s. Sostituisci %(st_code)sIP%(e_code)s con"
" l'indirizzo IP/hostname di questo NAS (lo puoi trovare nella pagina "
"Rete)."

#: frontend/templates/card.access.smb.html:111
msgid "When prompted, insert your credential."
msgstr "Quando richiesto, inserisci le tue credenziali."

#: frontend/templates/card.access.ssh.html:46
#, python-format
msgid ""
"The first time you connect, please accept the fingerprint by typing "
"%(st_code)syes%(e_code)s."
msgstr ""
"Quando ti connetti per la prima volta, accetta la fingerprint scrivendo "
"%(st_code)syes%(e_code)s."

#: frontend/templates/card.access.ssh.html:62
#, python-format
msgid "Download %(putty)s."
msgstr "Scarica %(putty)s."

#: frontend/templates/card.access.ssh.html:63
#, python-format
